rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Admin: custom claim OR email in list (keep list short; prefer custom claims)
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email in [
          'emekaanderson29@gmail.com'
        ]
      );
    }

    // Products: public read (active catalog), admin write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Users: self read/write own profile
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders: anyone may create (guest checkout). Read/update = owner or admin only.
    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin()
        || (signedIn() && resource.data.userId == request.auth.uid)
        || (resource.data.customer.email == request.auth.token.email);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Customers: create/update from client (signup/checkout tracking).
    // Full list read = admin only. A signed-in user may read their own doc.
    match /customers/{customerId} {
      allow create: if true;
      allow update: if true;
      allow read: if isAdmin()
        || (signedIn() && resource.data.email == request.auth.token.email);
      allow delete: if isAdmin();
    }
  }
}
